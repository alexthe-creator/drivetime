# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth2 (from Google Cloud Console - create an OAuth2 web app credential)
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//...   # generated by: node setup-oauth.js

# SQLite database path (optional - defaults to ./drivetime.db)
# On Railway, use a persistent volume mount path, e.g. /data/drivetime.db
# DB_PATH=/data/drivetime.db

# Port (Railway sets this automatically)
# PORT=3001
